<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Dashboard — Select Server</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">
  <%- include('partials/navbar') %>
  <div class="container py-5">
    <h2 class="fw-bold mb-4"><i class="fas fa-server me-2 text-primary"></i>Select a Server</h2>
    <% if (!guilds || guilds.length === 0) { %>
      <div class="alert alert-warning">No manageable servers found. Make sure you have <strong>Manage Server</strong> permission.</div>
    <% } %>
    <div class="row g-3">
      <% (guilds || []).forEach(guild => { %>
        <div class="col-md-4 col-lg-3">
          <a href="/dashboard/<%= guild.id %>" class="text-decoration-none">
            <div class="card border-0 h-100" style="background: #2b2d31; transition: transform .2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
              <div class="card-body text-center p-4">
                <% if (guild.icon) { %>
                  <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="rounded-circle mb-3" width="64" height="64">
                <% } else { %>
                  <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width:64px;height:64px;background:#5865F2;font-size:1.5rem;font-weight:bold;">
                    <%= guild.name[0] %>
                  </div>
                <% } %>
                <h6 class="fw-bold text-white mb-0"><%= guild.name %></h6>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
