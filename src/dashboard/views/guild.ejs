<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Server Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">
  <%- include('partials/navbar') %>
  <div class="d-flex">
    <%- include('partials/sidebar', { guildId }) %>
    <main class="flex-grow-1 p-4">
      <h2 class="fw-bold mb-4"><i class="fas fa-chart-line me-2 text-primary"></i>Overview</h2>
      <div class="row g-3" id="stats-cards">
        <div class="col-md-3"><div class="card border-0 text-center p-4" style="background:#2b2d31"><i class="fas fa-users fa-2x text-primary mb-2"></i><div class="fs-3 fw-bold" id="stat-members">—</div><div class="text-secondary">Members Tracked</div></div></div>
        <div class="col-md-3"><div class="card border-0 text-center p-4" style="background:#2b2d31"><i class="fas fa-exclamation-triangle fa-2x text-warning mb-2"></i><div class="fs-3 fw-bold" id="stat-warns">—</div><div class="text-secondary">Warnings</div></div></div>
        <div class="col-md-3"><div class="card border-0 text-center p-4" style="background:#2b2d31"><i class="fas fa-gift fa-2x text-danger mb-2"></i><div class="fs-3 fw-bold" id="stat-giveaways">—</div><div class="text-secondary">Active Giveaways</div></div></div>
        <div class="col-md-3"><div class="card border-0 text-center p-4" style="background:#2b2d31"><i class="fas fa-star fa-2x text-info mb-2"></i><div class="fs-3 fw-bold" id="stat-top">—</div><div class="text-secondary">Top Level</div></div></div>
      </div>
      <div class="mt-4">
        <h5 class="fw-bold mb-3">🏆 Top Members (Leveling)</h5>
        <div class="card border-0 p-3" style="background:#2b2d31">
          <table class="table table-dark table-hover mb-0">
            <thead><tr><th>#</th><th>User ID</th><th>Level</th><th>XP</th><th>Messages</th></tr></thead>
            <tbody id="top-users"></tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
  <script>
    const guildId = '<%= guildId %>';
    fetch(`/api/guild/${guildId}/stats`).then(r=>r.json()).then(d => {
      document.getElementById('stat-members').textContent = d.members;
      document.getElementById('stat-warns').textContent = d.warnings;
      document.getElementById('stat-giveaways').textContent = d.activeGiveaways;
      document.getElementById('stat-top').textContent = d.topUsers[0]?.level || 0;
      document.getElementById('top-users').innerHTML = (d.topUsers || []).map((u,i)=>
        `<tr><td>${i+1}</td><td>${u.id}</td><td>${u.level}</td><td>${u.xp}</td><td>${u.messages}</td></tr>`
      ).join('');
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
