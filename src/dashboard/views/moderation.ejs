<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Moderation</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet"></head>
<body class="bg-dark text-white">
<%- include('partials/navbar') %>
<div class="d-flex">
<%- include('partials/sidebar', { guildId }) %>
<main class="flex-grow-1 p-4">
  <h2 class="fw-bold mb-4"><i class="fas fa-shield-alt me-2 text-primary"></i>Moderation Cases</h2>
  <div class="card border-0 p-3" style="background:#2b2d31">
    <table class="table table-dark table-hover mb-0">
      <thead><tr><th>#</th><th>Type</th><th>User ID</th><th>Moderator ID</th><th>Reason</th><th>Date</th></tr></thead>
      <tbody id="cases-table"></tbody>
    </table>
  </div>
</main></div>
<script>
const guildId='<%= guildId %>';
fetch(`/api/guild/${guildId}/cases`).then(r=>r.json()).then(cases=>{
  const colors={ban:'text-danger',kick:'text-warning',warn:'text-info',timeout:'text-secondary'};
  document.getElementById('cases-table').innerHTML=cases.map((c,i)=>
    `<tr><td>${i+1}</td><td class="${colors[c.type]||''} fw-bold">${c.type.toUpperCase()}</td><td>${c.user_id}</td><td>${c.moderator_id}</td><td>${c.reason||'—'}</td><td>${new Date(c.created_at*1000).toLocaleDateString()}</td></tr>`
  ).join('')||'<tr><td colspan="6" class="text-center text-secondary">No cases yet.</td></tr>';
});
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
