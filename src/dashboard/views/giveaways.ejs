<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Giveaways</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet"></head>
<body class="bg-dark text-white">
<%- include('partials/navbar') %>
<div class="d-flex">
<%- include('partials/sidebar', { guildId }) %>
<main class="flex-grow-1 p-4">
  <h2 class="fw-bold mb-4"><i class="fas fa-gift me-2 text-danger"></i>Giveaways</h2>
  <div class="card border-0 p-3" style="background:#2b2d31">
    <table class="table table-dark table-hover mb-0">
      <thead><tr><th>Prize</th><th>Winners</th><th>Ends At</th><th>Status</th><th>Entries</th></tr></thead>
      <tbody id="giveaways-table"></tbody>
    </table>
  </div>
</main></div>
<script>
const guildId='<%= guildId %>';
fetch(`/api/guild/${guildId}/giveaways`).then(r=>r.json()).then(gs=>{
  document.getElementById('giveaways-table').innerHTML=gs.map(g=>{
    const entries=JSON.parse(g.entries||'[]').length;
    const ended=g.ended?'<span class="badge bg-secondary">Ended</span>':'<span class="badge bg-success">Active</span>';
    return `<tr><td>${g.prize}</td><td>${g.winners}</td><td>${new Date(g.ends_at*1000).toLocaleString()}</td><td>${ended}</td><td>${entries}</td></tr>`;
  }).join('')||'<tr><td colspan="5" class="text-center text-secondary">No giveaways yet.</td></tr>';
});
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
