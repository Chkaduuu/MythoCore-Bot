<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Welcomer</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet"></head>
<body class="bg-dark text-white">
<%- include('partials/navbar') %>
<div class="d-flex">
<%- include('partials/sidebar', { guildId }) %>
<main class="flex-grow-1 p-4">
  <h2 class="fw-bold mb-4"><i class="fas fa-door-open me-2 text-primary"></i>Welcomer Settings</h2>
  <div class="alert border-0" style="background:#2b2d31">
    <h5>Configure via Bot Commands</h5>
    <ul class="mb-0 text-secondary">
      <li><code>/setwelcome channel #channel</code> — Set welcome channel</li>
      <li><code>/setwelcome message {user} welcome!</code> — Set message (use {user}, {server}, {count})</li>
      <li><code>/setwelcome image true</code> — Enable welcome images</li>
      <li><code>/setwelcome test</code> — Preview welcome message</li>
    </ul>
  </div>
</main></div>
</body></html>
