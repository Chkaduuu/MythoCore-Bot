<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Leveling</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet"></head>
<body class="bg-dark text-white">
<%- include('partials/navbar') %>
<div class="d-flex">
<%- include('partials/sidebar', { guildId }) %>
<main class="flex-grow-1 p-4">
  <h2 class="fw-bold mb-4"><i class="fas fa-star me-2 text-info"></i>Leveling Configuration</h2>
  <div class="alert border-0" style="background:#2b2d31">
    <h5>Configure via Bot Commands</h5>
    <ul class="mb-0 text-secondary">
      <li><code>/rank</code> — View rank card</li>
      <li><code>/setrank</code> — Customize rank card colors</li>
      <li><code>/setlevelrole &lt;role&gt; &lt;level&gt;</code> — Add level role rewards</li>
      <li><code>/leaderboard levels</code> — View level leaderboard</li>
    </ul>
  </div>
</main></div>
</body></html>
