# ===========================
# DISCORD BOT CONFIGURATION
# ===========================
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
GUILD_ID=your_guild_id_here

# ===========================
# DATABASE (choose one)
# ===========================
DB_TYPE=sqlite
# Options: sqlite | mysql | mongodb

# SQLite (default, no setup needed)
SQLITE_PATH=./data/database.sqlite

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=discordbot

# MongoDB
MONGODB_URI=mongodb://localhost:27017/discordbot

# ===========================
# DASHBOARD
# ===========================
DASHBOARD_PORT=3000
DASHBOARD_SECRET=your_super_secret_session_key_change_this
DASHBOARD_URL=http://localhost:3000
DASHBOARD_CALLBACK=http://localhost:3000/auth/callback

# ===========================
# OPTIONAL: MUSIC
# ===========================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===========================
# OPTIONAL: APIs
# ===========================
WEATHER_API_KEY=
GIPHY_API_KEY=
